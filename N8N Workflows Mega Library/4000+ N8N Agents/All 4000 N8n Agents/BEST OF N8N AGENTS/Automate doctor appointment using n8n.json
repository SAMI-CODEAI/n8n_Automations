    },
    {
      "parameters": {
        "calendar": {
          "__rl": true,
          "value": "demo.calendar@example.com",
          "mode": "list",
          "cachedResultName": "demo.calendar@example.com"
        },
        "start": "={{ $fromAI('Start', '', 'string') }}",
        "end": "={{ $fromAI('End', '', 'string') }}",
        "additionalFields": {
          "summary": "={{ $fromAI('Summary', '', 'string') }}"
        }
      },
      "type": "n8n-nodes-base.googleCalendarTool",
      "typeVersion": 1.3,
      "position": [656, 224],
      "id": "calendar-create-node",
      "name": "Create",
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "DEMO_GOOGLE_CREDENTIAL",
          "name": "Google Calendar Account"
        }
      }
    },
    {
      "parameters": {
        "operation": "getAll",
        "calendar": {
          "__rl": true,
          "value": "demo.calendar@example.com",
          "mode": "list",
          "cachedResultName": "demo.calendar@example.com"
        },
        "limit": "={{ $fromAI('Limit', '', 'number') }}",
        "timeMin": "={{ $fromAI('After', '', 'string') }}",
        "timeMax": "={{ $fromAI('Before', '', 'string') }}",
        "options": {}
      },
      "type": "n8n-nodes-base.googleCalendarTool",
      "typeVersion": 1.3,
      "position": [784, 224],
      "id": "calendar-search-node",
      "name": "Search",
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "DEMO_GOOGLE_CREDENTIAL",
          "name": "Google Calendar Account"
        }
      }
    },
    {
      "parameters": {
        "options": {
          "timezone": "Asia/Kolkata"
        }
      },
      "type": "n8n-nodes-base.dateTimeTool",
      "typeVersion": 2,
      "position": [912, 224],
      "id": "datetime-node",
      "name": "Date and Time"
    },
    {
      "parameters": {
        "chatId": "={{ $('Telegram Trigger').item.json.message.chat.id }}",
        "text": "={{ $json.output }}",
        "additionalFields": {
          "appendAttribution": false,
          "parse_mode": "None"
        }
      },
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [944, 0],
      "id": "telegram-send",
      "name": "Send a text message",
