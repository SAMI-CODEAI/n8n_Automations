      "credentials": {
        "telegramApi": {
          "id": "DEMO_TELEGRAM_CREDENTIAL",
          "name": "Telegram Bot Account"
        }
      }
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.message.text }}",
