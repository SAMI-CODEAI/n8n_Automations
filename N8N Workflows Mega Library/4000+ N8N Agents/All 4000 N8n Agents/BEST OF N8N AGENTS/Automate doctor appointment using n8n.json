      "credentials": {
        "googlePalmApi": {
          "id": "DEMO_GOOGLE_PALM_CREDENTIAL",
          "name": "Google Gemini API"
        }
      }
    },
    {
      "parameters": {
        "sessionIdType": "customKey",
