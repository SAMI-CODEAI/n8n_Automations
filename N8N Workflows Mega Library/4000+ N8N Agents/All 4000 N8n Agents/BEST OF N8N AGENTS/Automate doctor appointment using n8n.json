{
  "name": "My workflow",
  "nodes": [
    {
      "parameters": {
        "updates": ["message"],
        "additionalFields": {}
      },
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.2,
      "position": [176, 0],
      "id": "telegram-trigger-node",
      "name": "Telegram Trigger",
