          "systemMessage": "Hospital Appointment System Instructions (Demo Version)"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [592, 0],
      "id": "agent-node",
      "name": "AI Agent"
    },
    {
      "parameters": {
        "options": {}
      },
